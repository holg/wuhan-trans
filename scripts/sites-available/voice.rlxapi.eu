# vtranslate-relay nginx config
# Install: /Users/htr/Documents/develeop/swift/wuhan-trans/scripts/deploy_to_server.sh install-nginx
# Then: sudo certbot --nginx -d voice.rlxapi.eu

server {
    server_name voice.rlxapi.eu;

    # WebSocket relay
    location /ws/ {
        proxy_pass http://127.0.0.1:3088;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    # REST API
    location / {
        proxy_pass http://127.0.0.1:3088;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    access_log /var/log/nginx/voice.rlxapi.eu.access.log;
    error_log  /var/log/nginx/voice.rlxapi.eu.error.log;

    listen 443 ssl; # managed by Certbot
	listen [::]:443 ssl;
    ssl_certificate /etc/letsencrypt/live/voice.rlxapi.eu/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/voice.rlxapi.eu/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}


server {
    if ($host = voice.rlxapi.eu) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name voice.rlxapi.eu;
    return 404; # managed by Certbot


}